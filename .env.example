# Online system host ports. Choose non-common ports to avoid local conflicts.
FRONTEND_HOST_PORT=22220
BACKEND_HOST_PORT=22221

# Backend listener inside the container.
BACKEND_BIND_ADDR=0.0.0.0
BACKEND_PORT=22221

# Backend runtime configuration.
GIN_MODE=release
ENV=production
JWT_SECRET_KEY=change-this-jwt-secret
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DATABASE_PATH=/app/database/crypto-custody.db

# Frontend origins that may call the backend directly. When the frontend uses
# same-origin /api through Nginx, CORS is mostly a fallback for local debugging.
CORS_ALLOWED_ORIGINS=http://localhost:22220,http://127.0.0.1:22220

# Ethereum RPC configuration. ETH_RPC_URL takes precedence. ETH_RPC is kept
# as a backward-compatible Infura project id fallback.
ETH_RPC_URL=
ETH_RPC=
ETH_CHAIN_ID=11155111
ETH_CONFIRM_TIMEOUT_SECONDS=60

# Optional image names used by docker compose and push scripts.
DOCKER_PLATFORM=linux/amd64
ONLINE_SERVER_IMAGE=ceyewan/crypto-custody-online-server:latest
ONLINE_CLIENT_IMAGE=ceyewan/crypto-custody-frontend:latest
