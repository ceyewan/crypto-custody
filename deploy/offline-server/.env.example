# Docker image to deploy.
OFFLINE_SERVER_IMAGE=ceyewan/crypto-custody-offline-server:latest
DOCKER_PLATFORM=linux/amd64

# HTTP API and WebSocket ports exposed by offline-server.
OFFLINE_WEB_PORT=8080
OFFLINE_WEB_HOST_PORT=8080
OFFLINE_WS_PORT=8081
OFFLINE_WS_HOST_PORT=8081

# This must be reachable by desktop clients.
# Use the offline server LAN IP or DNS name, for example: 192.168.1.10
OFFLINE_MANAGER_PUBLIC_HOST=127.0.0.1

# The manager port range must be exposed by Docker and opened in the firewall.
OFFLINE_MANAGER_PORT_START=18001
OFFLINE_MANAGER_PORT_END=18100

TZ=Asia/Singapore
